# Backend API (must include /api suffix)
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# If Next.js picks another port (e.g. 3002), backend CORS allows localhost in dev.
# For production, set FRONTEND_URL on the backend to your deployed origin.

# Google Maps — https://console.cloud.google.com/google/maps-apis
# Enable: Maps JavaScript API, Places API (New), Routes API (required for street routes on planner map)
# Optional fallback: Directions API (legacy)
# Restrict key to HTTP referrers: http://localhost:3000/* http://localhost:3001/* http://localhost:3002/*
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Stripe — https://dashboard.stripe.com/test/apikeys
# Use test keys (pk_test_... / sk_test_...) for development
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
