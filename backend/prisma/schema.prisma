generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  TRAVELER
  BUSINESS_OWNER
  ADMIN
}

enum PropertyType {
  HOTEL
  MOTEL
  GUESTHOUSE
  HOMESTAY
  BOUTIQUE_INN
  ECO_LODGE
}

enum PropertyStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
}

enum RoomType {
  SINGLE
  DOUBLE
  TWIN
  TRIPLE
  FAMILY
  DORM
  SUITE
  DELUXE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum SeasonType {
  PEAK
  OFF_SEASON
  WEEKEND
  HOLIDAY
}

enum HiddenGemCategory {
  ATTRACTION
  RESTAURANT
  EXPERIENCE
  CULTURAL_SITE
}

enum VerificationAction {
  SUBMITTED
  APPROVED
  REJECTED
  SUSPENDED
  RESUBMITTED
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  role          UserRole  @default(TRAVELER)
  firstName     String
  lastName      String
  phone         String?
  avatarUrl     String?
  isActive      Boolean   @default(true)
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  businessProfile BusinessProfile?
  refreshTokens   RefreshToken[]
  properties      Property[]
  bookings        Booking[]
  reviews         Review[]
  itineraries     Itinerary[]
  passwordResets  PasswordReset[]
  favorites       Favorite[]

  @@index([role])
  @@index([email])
}

model Favorite {
  id         String   @id @default(uuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
}

model BusinessProfile {
  id               String   @id @default(uuid())
  userId           String   @unique
  businessName     String
  businessLicense  String?
  taxId            String?
  verificationStatus PropertyStatus @default(PENDING_REVIEW)
  verifiedAt       DateTime?
  adminNotes       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordReset {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Property {
  id           String         @id @default(uuid())
  ownerId      String
  name         String
  type         PropertyType
  status       PropertyStatus @default(DRAFT)
  description  String         @db.Text
  address      String
  city         String
  country      String
  latitude     Float
  longitude    Float
  contactPhone String
  contactEmail String
  avgRating    Float          @default(0)
  reviewCount  Int            @default(0)
  approvedAt   DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  owner              User                 @relation(fields: [ownerId], references: [id])
  images             PropertyImage[]
  amenities          PropertyAmenity[]
  rooms              Room[]
  reviews            Review[]
  bookings           Booking[]
  verificationRecord VerificationRecord?
  favorites          Favorite[]

  @@index([city, country, status, type])
  @@index([avgRating])
  @@index([ownerId])
}

model VerificationRecord {
  id         String             @id @default(uuid())
  propertyId String             @unique
  status     PropertyStatus
  adminId    String?
  adminNotes String?            @db.Text
  action     VerificationAction
  createdAt  DateTime           @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model PropertyImage {
  id         String   @id @default(uuid())
  propertyId String
  url        String
  caption    String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model Amenity {
  id        String   @id @default(uuid())
  name      String   @unique
  icon      String?
  createdAt DateTime @default(now())

  properties PropertyAmenity[]
}

model PropertyAmenity {
  propertyId String
  amenityId  String

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  amenity  Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([propertyId, amenityId])
}

model Room {
  id              String   @id @default(uuid())
  propertyId      String
  name            String
  roomType        RoomType
  capacity        Int
  basePrice       Decimal  @db.Decimal(10, 2)
  description     String   @db.Text
  quantity        Int      @default(1)
  availableCount  Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  property     Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  images       RoomImage[]
  seasonalPrices SeasonalPrice[]
  availability RoomAvailability[]
  bookings     Booking[]

  @@index([propertyId])
}

model RoomImage {
  id        String   @id @default(uuid())
  roomId    String
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

model SeasonalPrice {
  id         String     @id @default(uuid())
  roomId     String
  seasonType SeasonType
  multiplier Decimal    @db.Decimal(4, 2)
  startDate  DateTime?
  endDate    DateTime?
  createdAt  DateTime   @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
}

model RoomAvailability {
  id        String   @id @default(uuid())
  roomId    String
  date      DateTime @db.Date
  available Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, date])
  @@index([roomId, date])
}

model Booking {
  id              String        @id @default(uuid())
  userId          String
  propertyId      String
  roomId          String
  checkIn         DateTime      @db.Date
  checkOut        DateTime      @db.Date
  guests          Int           @default(1)
  status          BookingStatus @default(PENDING)
  nights          Int
  baseTotal       Decimal       @db.Decimal(10, 2)
  finalTotal      Decimal       @db.Decimal(10, 2)
  platformFee     Decimal       @db.Decimal(10, 2)
  stripePaymentId   String?
  paymentExpiresAt  DateTime?
  cancelledAt       DateTime?
  confirmedAt       DateTime?
  completedAt       DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user     User     @relation(fields: [userId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])
  room     Room     @relation(fields: [roomId], references: [id])

  @@index([userId, status])
  @@index([roomId, checkIn, checkOut])
  @@index([propertyId])
}

model Review {
  id         String   @id @default(uuid())
  userId     String
  propertyId String
  bookingId  String?
  rating     Int
  title      String?
  content    String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id])
  property Property      @relation(fields: [propertyId], references: [id])
  images   ReviewImage[]

  @@unique([userId, propertyId])
  @@index([propertyId])
}

model ReviewImage {
  id       String @id @default(uuid())
  reviewId String
  url      String

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

model Itinerary {
  id           String   @id @default(uuid())
  userId       String
  destination  String
  country      String
  startDate    DateTime @db.Date
  endDate      DateTime @db.Date
  travelers    Int
  budget       Decimal  @db.Decimal(12, 2)
  interests    String[]
  totalCost    Decimal? @db.Decimal(12, 2)
  summary      String?  @db.Text
  rawResponse  Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  days ItineraryDay[]

  @@index([userId])
}

model ItineraryDay {
  id          String @id @default(uuid())
  itineraryId String
  dayNumber   Int
  title       String
  description String? @db.Text

  itinerary  Itinerary           @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  activities ItineraryActivity[]

  @@unique([itineraryId, dayNumber])
}

model ItineraryActivity {
  id          String  @id @default(uuid())
  dayId       String
  time        String?
  title       String
  description String? @db.Text
  location    String?
  cost        Decimal? @db.Decimal(10, 2)
  category    String?
  latitude    Float?
  longitude   Float?
  imageUrl    String?
  placeId     String?

  day ItineraryDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
}

model HiddenGem {
  id          String            @id @default(uuid())
  name        String
  description String            @db.Text
  category    HiddenGemCategory
  city        String
  country     String
  address     String?
  latitude    Float
  longitude   Float
  imageUrl    String?
  rating      Float             @default(0)
  priceRange  String?
  tags        String[]
  isFeatured  Boolean           @default(false)
  createdAt   DateTime          @default(now())

  @@index([city, country, category])
}

model PlatformAnalytics {
  id              String   @id @default(uuid())
  date            DateTime @db.Date @unique
  totalUsers      Int      @default(0)
  totalProperties Int      @default(0)
  totalBookings   Int      @default(0)
  totalRevenue    Decimal  @db.Decimal(14, 2) @default(0)
  newUsers        Int      @default(0)
  newBookings     Int      @default(0)
  createdAt       DateTime @default(now())
}
