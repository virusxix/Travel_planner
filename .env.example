# ============================================================
# HiddenStay — environment template (FastAPI + React + MongoDB)
# Copy the backend block to backend/.env and the frontend block
# to frontend/.env. Never commit the filled-in files.
# ============================================================

# ---------- backend/.env ----------
# MongoDB: local "mongodb://localhost:27017" for dev,
# Atlas "mongodb+srv://user:pass@cluster.mongodb.net" in production.
MONGO_URL="mongodb://localhost:27017"
DB_NAME="hiddenstay"

# Comma-separated allowed origins (no trailing slash). "*" for local dev.
CORS_ORIGINS="http://localhost:3000"

# AI Trip Planner — Groq is the default provider.
GROQ_API_KEY="gsk_..."
GROQ_MODEL="llama-3.3-70b-versatile"
AI_PROVIDER="groq"
OPENAI_API_KEY=""
GEMINI_API_KEY=""

# Google Maps (Maps JavaScript API + Places enabled in Cloud Console)
GOOGLE_MAPS_API_KEY="AIza..."

# Stripe (sandbox)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_MODE="test"

# ---------- frontend/.env ----------
# Local: http://127.0.0.1:8000 · Production: your Render URL (no trailing slash)
REACT_APP_BACKEND_URL="http://127.0.0.1:8000"
REACT_APP_GOOGLE_MAPS_API_KEY="AIza..."
